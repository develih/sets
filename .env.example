# Discord bot token from the Discord Developer Portal.
DISCORD_TOKEN=put_your_bot_token_here

# Public URL that points to this bot web server.
BASE_URL=https://edating.gay

# Local web server bind. Put this behind Nginx/Caddy/Cloudflare Tunnel for HTTPS.
HOST=0.0.0.0
PORT=8080

# Optional: put your test server ID here so slash command updates appear instantly.
# If empty, commands are global and Discord can take a while to show updates.
SYNC_GUILD_ID=1369848560321040484

# Optional: allow this role to use /send embed and /upload file.
# Users with Manage Server can already use those commands.
UPLOAD_ROLE_ID=

# Storage and limits.
DATA_DIR=data
MAX_FILES_PER_CATEGORY=10
MAX_UPLOAD_BYTES=2097152

# 0 means one-time links do not expire until used.
TOKEN_TTL_HOURS=0

# plugins category redirect/link.
PLUGIN_URL=https://gofile.io/d/hDh8Vu
